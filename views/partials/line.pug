mixin positionSelection(number, selectablePositions, noneSelectable)
    select(name="line"+ number + position)
        if noneSelectable
            option(value="noneSelected") None selected
        for player in players
            if player.positions.some(item => selectablePositions.includes(item))
                option(value=player._id)= player.user.name

mixin line(number)
    h4 Line #{number}
    table
        tr
            td LW
            td C
            td RW
        tr
            td
                +positionSelection(number, ['LW'], true)
            td
                +positionSelection(number, ['C'], true)
            td
                +positionSelection(number, ['RW'], true)
        tr
            td LD
            td
            td RD
        tr
            td
                +positionSelection(number, ['LD'], true)
            td
            td
                +positionSelection(number, ['RD'], true)

mixin powerplayLine(number)
    h4 Unit #{number}
    table
        tr
            td LW
            td C
            td RW
        tr
            td
                +positionSelection(number, ['LW', 'C', 'RW'])
            td
                +positionSelection(number, ['LW', 'C', 'RW'])
            td
                +positionSelection(number, ['LW', 'C', 'RW'])
        tr
            td LD
            td
            td RD
        tr
            td
                +positionSelection(number, ['LD', 'RD', 'LW', 'C', 'RW'])
            td
            td
                +positionSelection(number, ['LD', 'RD', 'LW', 'C', 'RW'])

mixin penaltyKillLine(number)
    h4 Unit #{number}
    table
        tr
            td Winger
            td C
        tr
            td
                +positionSelection(number, ['LW', 'C', 'RW'])
            td
                +positionSelection(number, ['LW', 'C', 'RW'])
        tr
            td LD
            td RD
        tr
            td
                +positionSelection(number, ['LD', 'RD'])
            td
                +positionSelection(number, ['LD', 'RD'])