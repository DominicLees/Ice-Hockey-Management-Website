head
    title #{player.user.name}'s Profile
    link(rel="stylesheet", href="/public/css/playerProfile.css")
body
    include partials/navbar.pug
    include partials/expandPositionCode.pug

    h1 #{player.user.name} - #{getPositionFullName(player.positions[0])} for #{player.team.name}

    div.stats
        div
            h3 Games
            p= player.totalGames
        div
            h3 Goals
            p= player.totalGoals
        div
            h3 Assists
            p= player.totalAssists
        div
            h3 Points
            p= player.totalGoals + player.totalAssists

    if player.totalGames > 0
        table
            thead
                tr
                    th Date
                    th Opponent
                    th Goals
                    th Assists
            tbody
                for game in player.games
                    tr
                        td= game.game.date
                        td= game.game.opponent
                        td= game.goals
                        td= game.assists