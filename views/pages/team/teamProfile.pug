head
    title= team.name
    link(rel="stylesheet", href="/public/css/teamProfile.css")
    script(src="/public/js/teamProfile-min.js" defer) 
body
    include /partials/navbar.pug
    h1= team.name
    h2 Head Coach: #{team.coach.name}
    if isCoach
        span Share this link with your players: 
        a(href="join/"+team.code) join/#{team.code}
        br
        button
            a(href=team.code+"/game/new") Create Game +
        br
        button#delete-team Delete Team
        br

    div.container
        if players
            div.content#players
                h2 Players
                table
                    thead
                        tr
                            th Name
                            th Positions
                    tbody
                        for player in players
                            tr
                                td= player.user.name
                                td= player.positions

        if games
            div.content#schedule
                h2 Schedule
                table
                    thead
                        tr
                            th Date
                            th Opponent
                    tbody
                        for game in games
                            tr
                                - var date = new Date(game.date)
                                td= date.toJSON().slice(0,10).split('-').reverse().join('/') + " at " + date.toLocaleTimeString()
                                td
                                    a(href="./" + team.code + "/game/" + game.gameId)= game.opponent